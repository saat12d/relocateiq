# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# Copy this file to .env and fill in your values.

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL for the FastAPI backend. Defaults to http://localhost:8000 if unset.
VITE_API_BASE_URL=http://localhost:8000

# ── Mapbox GL JS ──────────────────────────────────────────────────────────────
# Public (pk.*) token — safe to expose to the browser.
# Console: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here
