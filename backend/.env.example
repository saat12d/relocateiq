# ── Google Maps Platform ──────────────────────────────────────────────────────
# Enable: Geocoding API, Distance Matrix API, Directions API
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── TomTom ────────────────────────────────────────────────────────────────────
# Enable: Routing API, Traffic API
# Console: https://developer.tomtom.com/user/me/apps
TOMTOM_API_KEY=your_tomtom_key_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Powers AIExplanationService (GPT-4o or gpt-4o-mini recommended)
# Console: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# ── Housing Data (RentCast) ───────────────────────────────────────────────────
# Official API with a free tier (50 requests/month). Used by the
# RentCastListingProvider implementation of ListingProvider.
# Console: https://app.rentcast.io/app/api  →  generate an API key
RENTCAST_API_KEY=your_rentcast_key_here

# ── Mapbox (used by frontend; backend reads it to avoid embedding in JS bundle)
# Console: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_token_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/relocateiq
